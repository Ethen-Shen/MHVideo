{
  "name": "mhvideo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @mhvideo/api dev",
    "dev:admin": "pnpm --filter @mhvideo/admin dev",
    "dev:miniapp": "pnpm --filter @mhvideo/miniapp dev",
    "build:api": "pnpm --filter @mhvideo/api build",
    "build:admin": "pnpm --filter @mhvideo/admin build",
    "build:miniapp": "pnpm --filter @mhvideo/miniapp build",
    "lint": "eslint packages/*/src --ext .ts,.vue",
    "format": "prettier --write \"packages/*/src/**/*.{ts,vue,json,css}\"",
    "vercel-build": "pnpm install && pnpm --filter @mhvideo/api exec prisma generate && pnpm --filter @mhvideo/api build && pnpm --filter @mhvideo/admin build"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
