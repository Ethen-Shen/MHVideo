# ====================================
# 墨焕影视 - 后端 API 环境变量配置
# ====================================
# 使用方法：复制此文件为 .env，然后填入实际值
# cp .env.example .env
#
# Vercel 部署：在 Vercel Dashboard > Settings > Environment Variables 中
# 粘贴以下所有变量（不含注释行），填入实际值

# ---------- 数据库 ----------
# Vercel Postgres 连接字符串
# 在 Vercel Dashboard > Storage > Postgres 中创建数据库后获取
# 格式：postgresql://用户名:密码@主机:5432/数据库名?schema=public
DATABASE_URL="postgresql://user:password@host:5432/mhvideo?schema=public"

# ---------- JWT 认证 ----------
# JWT 密钥，用于生成和验证用户登录 Token
# 生产环境请使用随机生成的强密钥（至少32位）
# 可用命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="请替换为随机生成的密钥"

# JWT Token 有效期
JWT_EXPIRES_IN=7d

# JWT 刷新 Token 有效期
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Cloudflare R2 存储 ----------
# R2 API 端点
# 在 Cloudflare Dashboard > R2 > 管理 R2 API 令牌 中获取
# 格式：https://<账户ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://请替换为你的账户ID.r2.cloudflarestorage.com"

# R2 访问密钥 ID
R2_ACCESS_KEY_ID="请替换为你的R2访问密钥ID"

# R2 访问密钥
R2_SECRET_ACCESS_KEY="请替换为你的R2访问密钥"

# R2 存储桶名称（需在 Cloudflare R2 中提前创建）
R2_BUCKET_NAME="mhvideo"

# R2 公开访问域名
# 在 Cloudflare R2 存储桶设置 > 自定义域 中配置
# 格式：https://你的域名
R2_PUBLIC_URL="https://请替换为你的CDN域名"

# ---------- 文件上传 ----------
# 最大文件大小（字节），默认 500MB
UPLOAD_MAX_FILE_SIZE=524288000

# 允许的文件类型
UPLOAD_ALLOWED_TYPES=video/mp4,video/webm,video/quicktime,image/jpeg,image/png,image/webp

# ---------- 速率限制 ----------
# 速率限制时间窗口（毫秒），默认 15 分钟
RATE_LIMIT_WINDOW_MS=900000

# 速率限制最大请求数
RATE_LIMIT_MAX=100

# ---------- 服务器 ----------
# 服务端口（本地开发使用，Vercel 部署时忽略）
PORT=3000

# 运行环境
NODE_ENV="production"
